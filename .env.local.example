# ─────────────────────────────────────────────────────────────
# Executive AI Concierge Services — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# Supabase (required)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here

# RSA public key for client-side hybrid encryption (JSON Web Key format, stringified)
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Then convert to JWK using a library like node-jose
LEAD_ENCRYPTION_PUBLIC_KEY_JWK={"kty":"RSA","e":"AQAB","n":"your_public_key_modulus","alg":"RSA-OAEP-256","ext":true}

# Private key PEM for server-side decryption (keep highly secure)
LEAD_ENCRYPTION_PRIVATE_KEY_PEM=-----BEGIN RSA PRIVATE KEY-----\nyour_private_key_here\n-----END RSA PRIVATE KEY-----

# CRM / Gmail webhook URLs (optional — only fired for high-value leads)
CRM_WEBHOOK_URL=https://hooks.your-crm.com/executive-leads
GMAIL_ALERT_WEBHOOK_URL=https://hooks.your-email-system.com/alert

# Google Sheets fallback (set USE_GOOGLE_SHEETS_FALLBACK=true to enable)
USE_GOOGLE_SHEETS_FALLBACK=false
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nyour_private_key\n-----END PRIVATE KEY-----
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_SHEET_RANGE=ExecutiveAILeads!A:Q

# Executive Operations Assessment Platform
# Resend API key for emailing assessment reports (https://resend.com)
RESEND_API_KEY=your_resend_api_key_here

# Optional webhook fired when a high-intent assessment is completed or a consultation is requested
ASSESSMENT_CONSULTATION_WEBHOOK_URL=https://hooks.your-crm.com/assessment-consultations
